# tebra-content-os environment variables
# Copy to .env and fill in values. Never commit .env to git.
#
# Servers marked [claude.ai connector] are managed via claude.ai Settings > Connectors
# and do not require a .mcp.json entry. They appear as mcp__claude_ai_<Server>__* tools.
#
# Servers marked [custom MCP — v1.1 target] need a custom HTTP server. See RUNBOOK.md
# section 6 for deployment instructions.

# ---- Firecrawl ----
# Obtain at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# ---- Exa ----
# Obtain at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# ---- Google Search Console [custom MCP — v1.1 target] ----
# URL of your self-hosted or third-party Search Console MCP server.
# Tools exposed must include search_analytics_query.
SEARCH_CONSOLE_MCP_URL=
SEARCH_CONSOLE_API_KEY=

# ---- Google Analytics 4 [custom MCP — v1.1 target] ----
# URL of your self-hosted GA4 MCP server.
# Tools exposed must include run_report.
GA4_MCP_URL=
GA4_API_KEY=

# ---- Asana [custom MCP — v1.1 target] ----
# URL of your Asana MCP server. Alternatively, use claude.ai Asana connector
# (mcp__claude_ai_Asana__*) — connector does not support create_task/update_task
# as of April 2026; custom server required for those tools.
ASANA_MCP_URL=
ASANA_API_KEY=

# ---- HubSpot [custom MCP — v1.1 target] ----
HUBSPOT_MCP_URL=
HUBSPOT_API_KEY=

# ---- Claude.ai connectors (no env vars needed — managed in claude.ai settings) ----
# Slack          → mcp__claude_ai_Slack__*
# Google Drive   → mcp__claude_ai_Google_Drive__*
# Webflow        → mcp__claude_ai_Webflow__*

# ---- Chrome DevTools (managed via claude.ai plugin — no entry needed) ----
# Tools: mcp__plugin_chrome-devtools-mcp_chrome-devtools__*

# ---- Profound [future — v1.1 target] ----
# Share-of-citation tracking. No public MCP package as of April 2026.
# PROFOUND_API_KEY=

# ---- Peec AI [future — v1.1 target] ----
# Secondary citation tracking. No public MCP package as of April 2026.
# PEEC_AI_API_KEY=
