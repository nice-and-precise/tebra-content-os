{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-use-compliance.sh",
            "timeout": 30,
            "statusMessage": "Compliance check..."
          }
        ]
      }
    ]
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "auto"
  }
}
